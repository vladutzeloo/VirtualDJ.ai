# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# NVIDIA_API_KEY: NVIDIA NIM inference key (nvapi-...). Primary AI for DJ skills
# + taste analysis. OpenAI-compatible endpoint at https://integrate.api.nvidia.com/v1.
# Get one at https://build.nvidia.com.
NVIDIA_API_KEY="MY_NVIDIA_API_KEY"

# KIMI_API_KEY: Moonshot AI (Kimi) API key. Second link in the AI provider chain
# (used when NVIDIA is unavailable). OpenAI-compatible endpoint at
# https://api.moonshot.ai/v1. Get one at https://platform.moonshot.ai/console/api-keys
KIMI_API_KEY="MY_KIMI_API_KEY"

# Local LLM fallback: when NVIDIA and Kimi are both unavailable, the app falls back
# to whatever OpenAI-compatible server you have running locally (Ollama, LM Studio,
# llama.cpp, vLLM). The base URL and model are configured in the Neural Vault, not
# via env vars; defaults to http://localhost:11434/v1 (Ollama) with model llama3.2.
